# --- CONFIGURACIÓN DEL SERVIDOR ---
PORT=3000
NODE_ENV=production

# Restringir CORS en producción (ej. https://tudominio.com)
# Déjalo como * para desarrollo local
CORS_ORIGIN=https://tudominio.com

# Secreto para firmar sesiones JWT (genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=tu_jwt_secret_aqui

# --- CONFIGURACIÓN DE BASE DE DATOS ---
# 'json' = guarda localmente en data.json | 'mongodb' = MongoDB Atlas en la nube
DATABASE_TYPE=json

# Solo si usas DATABASE_TYPE=mongodb
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster0.xxxxx.mongodb.net/jobauto?retryWrites=true&w=majority

# --- CONFIGURACIÓN DE CORREO SMTP ---
SMTP_HOST=smtp.tuproveedor.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tu_correo@dominio.com
SMTP_PASS=tu_contraseña
SMTP_FROM="JobAuto" <tu_correo@dominio.com>

# Correo que recibe copia (CC) de todos los correos enviados (opcional)
SMTP_CC=

# --- CONFIGURACIÓN DE INTELIGENCIA ARTIFICIAL ---
# Llave de Google Gemini (Consíguela gratis en https://aistudio.google.com)
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Llave de Groq (Opcional - Consíguela en https://console.groq.com)
GROQ_API_KEY=tu_groq_api_key_aqui
