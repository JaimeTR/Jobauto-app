{
  "manifest_version": 3,
  "name": "JobAuto Extractor",
  "version": "1.5",
  "description": "Extrae ofertas de trabajo y proyectos freelance. Autopilot con paginacion y busqueda bilingue.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "*://*.infojobs.net/*",
        "*://*.getonbrd.com/*",
        "*://*.getonbrd.cl/*",
        "*://*.getonbrd.mx/*",
        "*://*.computrabajo.com/*",
        "*://*.computrabajo.com.pe/*",
        "*://*.bumeran.com/*",
        "*://*.bumeran.com.pe/*",
        "*://*.freelancer.com/*",
        "*://*.workana.com/*",
        "*://*.upwork.com/*",
        "*://*.guru.com/*",
        "*://*.fiverr.com/*",
        "*://*.contra.com/*",
        "*://*.peopleperhour.com/*",
        "*://*.toptal.com/*",
        "*://*.wellfound.com/*",
        "*://*.remoteok.com/*",
        "*://*.weworkremotely.com/*",
        "*://*.arc.dev/*",
        "*://*.google.com/maps/*",
        "*://*.google.com.pe/maps/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
